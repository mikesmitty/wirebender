{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>mikesmitty/renovate-config",
    ":automergeStableNonMajor",
    ":automergeDigest"
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "GOTOOLCHAIN \\?= go(?<currentValue>[\\d.]+)"
      ],
      "depNameTemplate": "golang",
      "datasourceTemplate": "golang-version"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "golang",
        "go"
      ],
      "allowedVersions": ">= 1.25.0 < 1.26.0"
    }
  ]
}
